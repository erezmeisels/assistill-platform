datasource db {
  provider = "postgresql"
  // url is supplied at runtime by the PrismaPg driver adapter (lib/prisma.ts)
  // and by prisma.config.ts for CLI commands (db push, migrate, etc.)
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CLIENT
  COMPANION
  ADMIN
}

enum Region {
  CENTER
  JERUSALEM
  NORTH
  SOUTH
}

enum PrimaryCategory {
  BUSINESS_PROFESSIONAL
  PERSONAL_SOCIAL
  LANGUAGE_TRANSLATION
  MENTORING_EDUCATION
}

enum SubCategory {
  // Business & Professional
  STRATEGIC_CONSULTING
  LEGAL_REGULATORY
  LOGISTICS_MOBILITY
  FINANCE_INVESTMENT
  REAL_ESTATE
  SECURITY_SAFETY
  // Personal & Social
  LOCAL_COMPANION
  SOCIAL_EVENT_HOST
  HEARTFELT_COMPANIONSHIP
  // Language & Translation
  TRANSLATION
  // Mentoring & Education
  CAREER_MENTORING
  ACADEMIC_SUPPORT
  PROFESSIONAL_DEVELOPMENT
}

enum LanguageLevel {
  NATIVE
  BUSINESS_FLUENT
}

enum BackgroundCheckStatus {
  NONE
  PENDING
  APPROVED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companionProfile CompanionProfile?
  reviews          Review[]
}

model CompanionProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  avatarUrl String?
  bio       String  @db.Text
  location  Region

  hourlyRate Decimal @db.Decimal(10, 2)
  dailyRate  Decimal @db.Decimal(10, 2)

  hasSignedNda          Boolean               @default(false)
  ndaSignedAt           DateTime?
  backgroundCheckStatus BackgroundCheckStatus @default(NONE)
  isApprovedByAdmin     Boolean               @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories     CompanionCategoryConfig[]
  skills         CompanionSkill[]
  languages      CompanionLanguage[]
  availabilities Availability[]
  reviews        Review[]
}

model CompanionCategoryConfig {
  id               String           @id @default(uuid())
  profileId        String
  companionProfile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  primaryCategory PrimaryCategory
  subCategory     SubCategory

  customHourlyRate Decimal? @db.Decimal(10, 2)
  customDailyRate  Decimal? @db.Decimal(10, 2)

  @@unique([profileId, subCategory])
}

model CompanionSkill {
  id               String           @id @default(uuid())
  profileId        String
  companionProfile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  skillTag String

  @@unique([profileId, skillTag])
}

model CompanionLanguage {
  id               String           @id @default(uuid())
  profileId        String
  companionProfile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  languageCode String
  level        LanguageLevel

  @@unique([profileId, languageCode])
}

model Availability {
  id               String           @id @default(uuid())
  profileId        String
  companionProfile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date     DateTime @db.Date
  isBooked Boolean  @default(false)

  @@unique([profileId, date])
}

model Review {
  id               String           @id @default(uuid())
  profileId        String
  companionProfile CompanionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  authorId         String
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([profileId, authorId])
}
